[Context]
filesystems=!xdg-run/app/com.discordapp.Discord;
features=bluetooth;
devices=all;input;
unset-environment=SDL_VIDEODRIVER;SDL_AUDIODRIVER;SDL_AUDIO_DRIVER;SDL_VIDEO_DRIVER;QT_STYLE_OVERRIDE;

[Environment]
SDL_VIDEODRIVER=
SDL_AUDIODRIVER=
SDL_AUDIO_DRIVER=
SDL_VIDEO_DRIVER=
QT_STYLE_OVERRIDE=
