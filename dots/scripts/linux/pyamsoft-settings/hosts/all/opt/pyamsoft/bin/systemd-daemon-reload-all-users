#!/bin/sh

# Source our common library
# shellcheck source=/opt/pyamsoft/lib/common
. "${PYAMSOFT_PATH}/lib/common"

NAME="$(basename "$0")"

# Reload systemctl for system
# And our current user
# And all other container users

_system() {
  _log 'Reload systemd at SYSTEM level...'
  sudo systemctl daemon-reload || {
    _elog 'Failed to reload at SYSTEM level'
    return 1
  }

  return 0
}

_user() {
  _log 'Reload systemd at USER level...'
  systemctl --user daemon-reload || {
    _elog 'Failed to reload at USER level'
    return 1
  }

  return 0
}

_containers() {
  _log 'Reload systemd at CONTAINER level...'

  container-all reload || {
    _elog 'Failed to reload at CONTAINER level'
    return 1
  }

  return 0
}

main() {
  if _has_function systemctl >/dev/null; then
    _system || return 1
    _user || return 1

    if _has_function container-all >/dev/null; then
      _containers || return 1
    fi
  fi
  return 0
}

main "$@" || exit 1
exit 0
