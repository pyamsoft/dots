#!/bin/sh

# Execute a shell as a containers-* user, even if the user's shell is
# set as /bin/nologin

# Source our common library
# shellcheck source=/opt/pyamsoft/lib/common
. "${PYAMSOFT_PATH}/lib/common"

NAME="$(basename "$0")"

_runas() {
  _who="$1"

  if _has_function run0 >/dev/null 2>&1; then
    # Use run0 if we have it
    # Run a bash login shell directly
    # Some users may have the shell set to /bin/nologin, explicitly use bash
    exec sudo run0 -u "${_who}" --setenv=SHELL=/bin/bash /bin/bash -l
  else
    # Otherwise fake the environment with sudo
    # Run a bash login shell directly
    # Some users may have the shell set to /bin/nologin, explicitly use bash
    exec sudo -u "${_who}" env SHELL=/bin/bash XDG_RUNTIME_DIR="/run/user/$(id -u "${_who}")" /bin/bash -l
  fi
}

main() {
  # Support the "containers" user or "containers-" delegate
  if [ "$1" = "containers" ]; then
    _user="$1"
  else
    _user="containers-$1"
  fi

  if ! id -un "${_user}" >/dev/null 2>&1; then
    _elog 'Target user %s does not exist' "${_user}"
    return 1
  fi

  _runas "${_user}" || return 1

  unset _user

  return 0
}

main "$@" || exit 1
exit 0
