#!/bin/sh

# Source our common library
# shellcheck source=/opt/pyamsoft/lib/common
. "${PYAMSOFT_PATH}/lib/common"

NAME="$(basename "$0")"

for adir in ./*/; do
  cd "${adir}" || {
    _elog 'Failed to cd into %s' "${adir}"
    exit 1
  }

  eval "$*" || {
    _elog 'Eval of command failed: "%s"' "$*"
    exit 2
  }

  cd .. || {
    _elog 'Failed to cd out of %s' "${adir}"
    exit 1
  }
done
