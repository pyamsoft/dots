#!/bin/sh

# Source our common library
# shellcheck source=/opt/pyamsoft/lib/common
. "${PYAMSOFT_PATH}/lib/common"

NAME="$(basename "$0")"

_stale_unlink() {
  rm -f "$1" || {
    _elog '[ERROR] Failed removing dangling file: %s' "$1"
    return 1
  }

  return 0
}

_remove_holdovers() {
  _log '[LOG] We remove old device symlinks and logs.'
  _log '[LOG] Sunshine sometimes has a problem cleaning these up and refuses to start...\n'

  # Bad symlinks
  _stale_unlink "${HOME}/.config/sunshine/sunshine_keyboard" || return 1
  _stale_unlink "${HOME}/.config/sunshine/sunshine_mouse" || return 1
  _stale_unlink "${HOME}/.config/sunshine/sunshine_touchscreen" || return 1

  # Logs
  _stale_unlink "${HOME}/.config/sunshine/sunshine.log" || return 1

  return 0
}

_unlock_linux() {
  _s="$1"

  loginctl unlock-session "${_s}" || {
    _elog '[ERROR] Failed unlocking session: %s (%s)' "${_s}" "${_uid}:${_username}"
    return 1
  }

  _log '[LOG] Unlocked user session %s (%s)' "${_s}" "${_uid}:${_username}"
  unset _s
  return 0
}

_unlock_macos() {
  _s="$1"

  # How do we unlock MacOS? Do we need to?
  if _has_function unlocker; then
    unlocker unlock || {
      _elog '[ERROR] Failed unlocking session: %s (%s)' "${_s}" "${_uid}:${_username}"
      return 1
    }

    _log '[LOG] Unlocked user session %s (%s)' "${_s}" "${_uid}:${_username}"
  fi

  unset _s
  return 0
}

_unlock_session() {
  _session_to_unlock="$1"

  if _is_macos; then
    _unlock_macos "${_session_to_unlock}" || return 1
  else
    _unlock_linux "${_session_to_unlock}" || return 1
  fi

  unset _session_to_unlock
  return 0
}

_list_sessions_linux() {
  # Get only the session ID and the user name
  # Only 'user' sessions, (instead of blank or "manager")
  # Only sessions for our active user
  # Match with spaces just in case a name is a part of another name
  loginctl list-sessions --no-legend | grep "user" | awk '{ print $1 " " $2 " " $3 }' | grep " $(id -u) $(id -un)" | awk '{ print $1 }' || return 1

  return 0
}

_list_sessions_macos() {
  # How do we list sessions on MacOS? Do we need to?
  printf -- ' ' || return 1
  return 0
}

_unlock_sessions() {
  _log '[LOG] We unlock all user-sessions'
  _log '[LOG] Sunshine will not be able to claim the CPU and GPU for rendering otherwise.\n'

  if _is_macos; then
    _user_sessions="$(_list_sessions_macos)"
  else
    _user_sessions="$(_list_sessions_linux)"
  fi

  for _session_num in ${_user_sessions}; do
    _unlock_session "${_session_num}" || return 1
    unset _session_num
  done

  unset _user_sessions
  return 0
}

_stop_sunshine_linux() {
  systemctl --user stop app-dev.lizardbyte.app.Sunshine >/dev/null 2>&1 || return 1
  return 0
}

_start_sunshine_linux() {
  systemctl --user restart app-dev.lizardbyte.app.Sunshine >/dev/null 2>&1 || return 1
  return 0
}

_stop_sunshine_macos() {
  # Use the beta branch for now on MacOS
  brew services stop sunshine-beta >/dev/null 2>&1 || return 1
  return 0
}

_start_sunshine_macos() {
  # Use the beta branch for now on MacOS
  brew services restart sunshine-beta >/dev/null 2>&1 || return 1
  return 0
}

_stop_sunshine() {
  if _is_macos; then
    _stop_sunshine_macos || return 1
  else
    _stop_sunshine_linux || return 1
  fi

  return 0
}

_start_sunshine() {
  if _is_macos; then
    _start_sunshine_macos || return 1
  else
    _start_sunshine_linux || return 1
  fi

  return 0
}

_restart() {
  _log '[LOG] Stopping old sunshine service...\n'

  _stop_sunshine || return 1

  # Kill any potentially bad symlinks
  _remove_holdovers || return 1

  # Unlock all sessions (if a session is locked, it causes sunshine to be unable to claim the display and GPU/CPU)
  _unlock_sessions || return 1

  _log '[LOG] Starting new sunshine service...\n'

  _start_sunshine || return 1

  return 0
}

_restart_sunshine() {
  _log '[LOG] Restarting Sunshine gamestream...'

  # If we can, we should poke the monitor first just to be safe
  if _has_function poke-monitor >/dev/null 2>&1; then
    _log -- '[LOG] Poking the monitor first before doing Sunshine things, just in case...'

    # Just give it our best shot.
    poke-monitor auto || {
      _elog '[WARN] Poking the monitor failed, continue with Sunshine things anyway.'
    }
  fi

  if _restart; then
    _log '[LOG] Restarted sunshine service!'
  else
    _log '[ERROR] Failed to restart sunshine'
    return 1
  fi

  return 0
}

main() {
  if _has_function sunshine >/dev/null 2>&1; then
    _restart_sunshine || return 1
    return 0
  else
    # On MacOS sometimes we are not on the PATH
    if _is_macos; then
      # Use the beta branch for now on MacOS
      if [ -e /opt/homebrew/bin/sunshine-beta ]; then
        _restart_sunshine || return 1
        return 0
      fi
    fi

    _log '[ERROR] sunshine is not installed.'
    exit 1
  fi
}

main "$@" || exit 1
exit 0
