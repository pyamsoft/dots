#!/bin/sh

# Install the real machine's bash configuration into a flatpak application
#
# Makes it easier to run a nice bash shell in a flatpak container

# Source our common library
. "${PYAMSOFT_PATH}/lib/common"

NAME="$(basename "$0")"

_require_bash_environment() {
  if [ ! -f "${HOME}/.bashrc" ]; then
    _elog 'Need a .bashrc at %s' "${HOME}/.bashrc"
    return 1
  fi

  if [ ! -f "${HOME}/.bash_profile" ]; then
    _elog 'Need a .bash_profile at %s' "${HOME}/.bash_profile"
    return 1
  fi

  if [ -n "${XDG_CONFIG_HOME}" ]; then
    if [ ! -d "${XDG_CONFIG_HOME}/bash" ]; then
      _elog 'Need bash configuration at %s' "${XDG_CONFIG_HOME}/bash"
      return 1
    fi
  else
    if [ ! -d "${HOME}/.config/bash" ]; then
      _elog 'Need bash configuration at %s' "${HOME}/.config/bash"
      return 1
    fi
  fi

  return 0
}

_install_bash_environment() {
  _install_flatpak_id="$1"

  mkdir -p "${_install_flatpak_id}/config/" || {
    _elog 'Failed to setup configuration directory %s' "${_install_flatpak_id}/config/"

    unset _install_flatpak_id
    return 1
  }

  if [ -n "${XDG_CONFIG_HOME}" ]; then
    cp -r "${XDG_CONFIG_HOME}/bash" "${_install_flatpak_id}/config/" || {
      _elog 'Failed to install bash configuration to %s' "${_install_flatpak_id}/config/"

      unset _install_flatpak_id
      return 1
    }

    # Optional starship install
    if [ -e "${XDG_CONFIG_HOME}/starship.toml" ]; then
      cp "${XDG_CONFIG_HOME}/starship.toml" "${_install_flatpak_id}/config/" || {
        _elog 'Failed to install starship configuration to %s' "${_install_flatpak_id}/config/"

        unset _install_flatpak_id
        return 1
      }
    fi
  else
    cp -r "${HOME}/.config/bash" "${_install_flatpak_id}/config/" || {
      _elog 'Failed to install bash configuration to %s' "${_install_flatpak_id}/config/"

      unset _install_flatpak_id
      return 1
    }

    # Optional starship install
    if [ -e "${HOME}/.config/starship.toml" ]; then
      cp "${HOME}/.config/starship.toml" "${_install_flatpak_id}/config/" || {
        _elog 'Failed to install starship configuration to %s' "${_install_flatpak_id}/config/"

        unset _install_flatpak_id
        return 1
      }
    fi
  fi

  cp -r "${HOME}/.bashrc" "${_install_flatpak_id}/.bashrc" || {
    _elog 'Failed to install .bashrc to %s' "${_install_flatpak_id}/.bashrc"

    unset _install_flatpak_id
    return 1
  }

  cp -r "${HOME}/.bash_profile" "${_install_flatpak_id}/.bash_profile" || {
    _elog 'Failed to install .bash_profile to %s' "${_install_flatpak_id}/.bash_profile"

    unset _install_flatpak_id
    return 1
  }

  unset _install_flatpak_id
  return 0
}

_install_starship() {
  _starship_flatpak_id="$1"

  mkdir -p "${_starship_flatpak_id}/.local/bin/" || {
    _elog 'Failed to create bin directory %s' "${_starship_flatpak_id}/.local/bin"

    unset _starship_flatpak_id
    return 1
  }

  cp /usr/bin/starship "${_starship_flatpak_id}/.local/bin/starship" || {
    _elog 'Failed to install starship to %s' "${_starship_flatpak_id}/.local/bin/starship"

    unset _starship_flatpak_id
    return 1
  }

  unset _starship_flatpak_id

  return 0
}

main() {
  _require_bash_environment || return 1

  _flatpak_id="$1"

  if [ -z "${_flatpak_id}" ]; then
    _elog 'Must pass flatpak ID'

    unset _flatpak_id
    return 1
  fi

  _flatpak_directory="${HOME}/.var/app/${_flatpak_id}"
  if [ ! -d "${_flatpak_directory}" ]; then
    _elog 'flatpak app directory must exist at %s' "${_flatpak_directory}"

    unset _flatpak_directory
    unset _flatpak_id
    return 1
  fi

  _install_bash_environment "${_flatpak_directory}" || return 1
  _install_starship "${_flatpak_directory}" || return 1

  unset _flatpak_directory
  unset _flatpak_id

  return 0
}

main "$@" || exit 1
exit 0
