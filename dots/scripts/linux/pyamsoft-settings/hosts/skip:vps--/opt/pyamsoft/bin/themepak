#!/bin/sh

# Copy real themes over to flatpak friendly locations

# Source our common library
# shellcheck source=/opt/pyamsoft/lib/common
. "${PYAMSOFT_PATH}/lib/common"

NAME="$(basename "$0")"

_do__theme() {
  _log 'Copy theme into flatpak: "%s"' "${__theme}"

  _t="/usr/share/themes/${__theme}"
  if [ -z "$1" ] || [ ! -d "${_t}" ]; then
    _elog 'Sorry, theme %s does not exist on host!' "${_t}"
    unset _t
    return 1
  fi

  # Copy theme
  mkdir -p "${HOME}/.themes"
  cp -r "${_t}" "${HOME}/.themes"
  if [ "${__dark}" -eq 1 ]; then
    _t="/usr/share/themes/${__theme}-Dark"
    if [ -d "${_t}" ]; then
      _log 'Copy dark theme into flatpak: "%s"' "${__theme}-Dark"
      cp -r "${_t}" "${HOME}/.themes"
    fi

    _t="/usr/share/themes/${__theme}-dark"
    if [ -d "${_t}" ]; then
      _log 'Copy dark theme into flatpak: "%s"' "${__theme}-dark"
      cp -r "${_t}" "${HOME}/.themes"
    fi

    _t="/usr/share/themes/${__theme}_Dark"
    if [ -d "${_t}" ]; then
      _log 'Copy dark theme into flatpak: "%s"' "${__theme}_Dark"
      cp -r "${_t}" "${HOME}/.themes"
    fi

    _t="/usr/share/themes/${__theme}_dark"
    if [ -d "${_t}" ]; then
      _log 'Copy dark theme into flatpak: "%s"' "${__theme}_dark"
      cp -r "${_t}" "${HOME}/.themes"
    fi
  fi

  unset _t
  return 0
}

_do__icon() {
  _log 'Copy icons into flatpak: "%s"' "${__icon}"

  _i="/usr/share/icons/${__icon}"
  if [ -z "$1" ] || [ ! -d "${_i}" ]; then
    _elog 'Sorry, icon %s does not exist on host!' "${_i}"
    unset _i
    return 1
  fi

  # Copy theme
  mkdir -p "${HOME}/.icons"
  cp -r "${_i}" "${HOME}/.icons"
  if [ "${__dark}" -eq 1 ]; then
    _i="/usr/share/icons/${__icon}-Dark"
    if [ -d "${_i}" ]; then
      _log 'Copy dark icons into flatpak: "%s"' "${__icon}-Dark"
      cp -r "${_i}" "${HOME}/.icons"
    fi

    _i="/usr/share/icons/${__icon}-dark"
    if [ -d "${_i}" ]; then
      _log 'Copy dark icons into flatpak: "%s"' "${__icon}-dark"
      cp -r "${_i}" "${HOME}/.icons"
    fi

    _i="/usr/share/icons/${__icon}_Dark"
    if [ -d "${_i}" ]; then
      _log 'Copy dark icons into flatpak: "%s"' "${__icon}_Dark"
      cp -r "${_i}" "${HOME}/.icons"
    fi

    _i="/usr/share/icons/${__theme}_dark"
    if [ -d "${_i}" ]; then
      _log 'Copy dark icons into flatpak: "%s"' "${__icon}_dark"
      cp -r "${_i}" "${HOME}/.icons"
    fi
  fi

  unset _i
  return 0
}

main() {
  __theme=""
  __icon=""
  __dark=0

  if [ -z "$1" ]; then
    _elog 'No options. Must be one of ["-d|--dark"] <"-t|--theme" "-i|--icon">'
    return 1
  fi

  while [ -n "$1" ]; do
    case "$1" in
    -d | --dark)
      __dark=1
      shift
      ;;
    -t | --theme)
      shift
      __theme="$1"
      shift
      ;;
    -i | --icon)
      shift
      __icon="$1"
      shift
      ;;
    *)
      _elog 'Invalid option: "%s\". Must be one of ["-d|--dark"] <"-t|--theme" "-i|--icon">' "$1"
      return 1
      ;;
    esac
  done

  if [ -z "${__theme}" ] && [ -z "${__icon}" ]; then
    _elog 'No options. Must be one of ["-d|--dark"] <"-t|--theme" "-i|--icon">'
    return 1
  fi

  readonly __theme
  readonly __icon
  readonly __dark

  if [ -n "${__theme}" ]; then
    _do__theme "${__theme}" || return 1
  fi

  if [ -n "${__icon}" ]; then
    _do__icon "${__icon}" || return 1
  fi

  return 0
}

main "$@" || exit 1
exit 0
