#!/bin/sh

# rofi 2.X
#
# For some reason, new version of rofi 2 which bring Native wayland support break specifically
# on GNOME Wayland, because GNOME does not support the layer-shell protocol (that everyone else does -_-)
#
# To avoid breaking behavior since I like rofi, we use this alias script to force rofi to run
# using X11 backend, instead of Wayland
#
# We also must run with `normal-window` to receive keyboard input
#
# This script can be dropped-in to places like GNOME keyboard shortcuts

_rofi_wayland_display="${WAYLAND_DISPLAY}"
unset WAYLAND_DISPLAY

_is_hidpi() {
  # Grab the current horizontal resolution from xrandr
  #
  # silence the warning about xwayland
  # grab the first digit in XxY+0+0 and then remove the `x`
  _horiz_size="$(xrandr 2>/dev/null | grep 'connected primary ' | grep -o -E '[[:digit:]]+x' | sed 's/x//')"

  # xrandr 2>/dev/null | grep 'connected primary ' | grep '[[:digit:]]+x' | sed 's/x//'

  # If our monitor is bigger than 3000px horizontal, we assume HiDPI :)
  #
  # Yeah this is a bad check.
  if [ "${_horiz_size}" -gt 3000 ]; then
    return 0
  else
    return 1
  fi
}

# Unset the WAYLAND_DISPLAY so that rofi can run, but re-set it for the executed program
# because we may want to use Wayland
#
# We must do it this way since rofi passes it's environment to the cmd

# If we are using a HiDPI display, set the DPI flag
if _is_hidpi; then
  WAYLAND_DISPLAY='' exec rofi -dpi 168 -normal-window -run-command "env WAYLAND_DISPLAY=${_rofi_wayland_display} {cmd}" "$@"
else
  WAYLAND_DISPLAY='' exec rofi -normal-window -run-command "env WAYLAND_DISPLAY=${_rofi_wayland_display} {cmd}" "$@"
fi
