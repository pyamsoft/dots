#!/bin/sh

# Extracts youtube-dl contents into MP3 using best quality and ignoring errors

# Source our common library
. "${PYAMSOFT_PATH}/lib/common"

NAME="$(basename "$0")"

dlp=""
if _has_function yt-dlp >/dev/null; then
  dlp="yt-dlp"
else
  dlp="youtube-dl"
fi

exec "${dlp}" --yes-playlist -x --audio-format mp3 --audio-quality 0 -i "$@"
