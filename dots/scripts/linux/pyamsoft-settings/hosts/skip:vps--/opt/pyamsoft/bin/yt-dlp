#!/bin/sh

# Source our common library
. "/opt/pyamsoft/lib/container-launch"

NAME="yt-dlp"
IMAGE="ghcr.io/jauderho/yt-dlp"
TAG="2026.06.09"

CONTAINER_REQUIRE_RUNCONF=0

_prep_mounts() {
  _mount_bind "${CONTAINER_RUNTIME_DIR}/${NAME}/downloads" "/downloads" || return 1
  return 0
}

_prep_caps() {
  return 0
}

_prep_env() {
  return 0
}

_prep_network() {
  _network_isolate || return 1
  return 0
}

_prep_ports() {
  return 0
}

_check_user() {
  _require_nonroot || return 1

  # Keep the real user ID instead of using the container default of root
  _add_userns --user="$(id -u):$(id -g)"

  if _is_podman; then
    _add_userns --userns keep-id
  fi

  return 0
}

_finalize() {
  _add_rc --read-only
  return 0
}

main "$@" || exit 1
exit 0
