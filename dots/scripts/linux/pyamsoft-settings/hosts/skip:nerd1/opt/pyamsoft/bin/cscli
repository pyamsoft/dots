#!/bin/sh

# Source our common library
# shellcheck source=/opt/pyamsoft/lib/container-launch
. "${PYAMSOFT_PATH}/lib/container-launch"

NAME="$(basename "$0")"

if [ "${_uid}" -eq 0 ]; then
  exec "${CONTAINER_CMD}" exec -i -t crowdsec cscli "$@"
else
  exec sudo "${CONTAINER_CMD}" exec -i -t crowdsec cscli "$@"
fi
