#!/bin/sh

# Source our common library
# shellcheck source=/opt/pyamsoft/lib/common
. "${PYAMSOFT_PATH}/lib/common"

readonly _pak="com.jetbrains.WebStorm"

# Send a notify message or log to the console when migration is needed
_notify_migrate() {
  _migrate_from="$1"
  _migrate_to="$2"

  _msg="You should migrate your tmpfs-mounter from ${_migrate_from} => ${_migrate_to}"

  if _has_function notify-send; then
    notify-send "${_pak} Migration Recommended" "${_msg}"
  fi

  _log "${_pak}: ${_msg}"

  unset _msg
  unset _migrate_from
  unset _migrate_to

  return 0
}

_warn_outdated() {
  _my_user_home="$(systemd-escape "${HOME}")"

  _dir="$(printf -- '%s' "/etc/systemd/system/local-fs.target.wants/tmpfs-mounter@${_username}:${_my_user_home}-.var-app-com.jetbrains.WebStorm-cache-JetBrains-WebStorm"*"-caches:mode\x3d0700\x2cnoexec.service")"

  case "${_dir}" in
  *\**)
    # No directory, nothing to warn about
    unset _dir

    unset _my_user_home

    return 0
    ;;
  *) ;;
  esac

  # Version like 2025.2.2
  _cache_version="$(printf -- '%s' "${_dir}" | grep -oE 'WebStorm[0-9]+(\.[0-9]+)+' | sed 's/WebStorm//')"

  # Full version with rel, 2025.2.3.4. We don't care about rel
  # split by spaces per code
  _current_version_str="$(flatpak info "${_pak}" | grep 'Version: ' | grep -oE '[0-9]+(\.[0-9]+)+' | tr '.' ' ')"

  _current_version_maj="$(printf -- '%s' "${_current_version_str}" | awk '{ print $1 }')"
  _current_version_min="$(printf -- '%s' "${_current_version_str}" | awk '{ print $2 }')"
  _current_version_patch="$(printf -- '%s' "${_current_version_str}" | awk '{ print $3 }')"
  _current_version="${_current_version_maj}.${_current_version_min}.${_current_version_patch}"

  # Make sure our current version starts with the cached one
  case "${_current_version}" in
  "${_cache_version}" | "${_cache_version}".*) ;;
  *)
    _notify_migrate "${_cache_version}" "${_current_version}" || {
      unset _my_user_home

      unset _current_version

      unset _current_version_patch
      unset _current_version_min
      unset _current_version_maj
      unset _current_version_str

      unset _cache_version

      return 1
    }
    ;;
  esac

  unset _my_user_home

  unset _current_version

  unset _current_version_patch
  unset _current_version_min
  unset _current_version_maj
  unset _current_version_str

  unset _cache_version
  return 0
}

readonly def_path="/app/bin:/usr/bin"
readonly dev_root="${HOME}/devel"

# Extensions
readonly _nodejs="node24"

# Local scripts
path="${HOME}/.local/bin"

readonly path

_warn_outdated

_java_wayland=1
_args=""
_after_args=""
while [ -n "$1" ]; do
  case "$1" in
  --shell)
    _args="${_args} --command=/bin/bash"

    # In shell mode, add the other path bits
    path="${path}:/usr/lib/sdk/${_nodejs}/bin"
    path="${path}:${HOME}/.var/app/com.jetbrains.WebStorm/data/node/bin"
    path="${path}:${HOME}/.var/app/com.jetbrains.WebStorm/data/cargo/bin"
    path="${path}:${HOME}/.var/app/com.jetbrains.WebStorm/data/python/bin"
    shift

    # Do not pass java wayland
    _java_wayland=0
    ;;
  --offline)
    _args="${_args} --unshare=network"
    shift
    ;;
  *)
    break
    ;;
  esac
done
readonly _args

if [ "${XDG_CURRENT_DESKTOP}" = "GNOME" ]; then
  if [ "${_java_wayland}" -eq 1 ]; then
    _after_args="-Dawt.toolkit.name=WLToolkit"
  fi
fi

readonly _after_args

# shellcheck source=/opt/pyamsoft/lib/common
readonly FP_ENV="${PYAMSOFT_PATH}/flatpak/lib/flatpak-env"

# GNOME supports wayland, but it crashes on KDE
if [ "${XDG_CURRENT_DESKTOP}" = "GNOME" ]; then
  # shellcheck disable=SC2086
  exec "${FP_ENV}" "${_pak}" \
    --with-env PATH "${path}:" "${def_path}" \
    --filesystem="${dev_root}/project/pyamsoft/tools" \
    --filesystem="${dev_root}/project/pyamsoft/js" \
    --filesystem="${dev_root}/project/pyamsoft/shell" \
    --env="FLATPAK_ENABLE_SDK_EXT=${_nodejs}" \
    --socket=wayland \
    ${_args} \
    -- \
    ${_after_args} \
    "$@" || exit 1
else
  # shellcheck disable=SC2086
  exec "${FP_ENV}" "${_pak}" \
    --with-env PATH "${path}:" "${def_path}" \
    --filesystem="${dev_root}/project/pyamsoft/tools" \
    --filesystem="${dev_root}/project/pyamsoft/js" \
    --filesystem="${dev_root}/project/pyamsoft/shell" \
    --env="FLATPAK_ENABLE_SDK_EXT=${_nodejs}" \
    ${_args} \
    -- \
    ${_after_args} \
    "$@" || exit 1
fi
exit 0
