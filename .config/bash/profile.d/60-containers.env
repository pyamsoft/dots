# shellcheck shell=bash

# Docker scrips
if command -v docker >/dev/null || command -v podman >/dev/null; then
  if [ -d "/opt/pyamsoft/containers/bin" ]; then
    prepend_path "/opt/pyamsoft/containers/bin"
  fi
fi

# Distrobox scrips
if command -v distrobox >/dev/null; then
  if [ -d "/opt/pyamsoft/distrobox/bin" ]; then
    prepend_path "/opt/pyamsoft/distrobox/bin"
  fi
fi

# Export the PATH
export PATH

return 0

# vim: set filetype=sh:
