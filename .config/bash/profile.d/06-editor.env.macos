# shellcheck shell=bash

case "$-" in
*i*)
  # Continue as normal
  ;;
*)
  # Stop if not running interactively
  return 0
  ;;
esac

# User editor can be from a local script
# Use absolute path to editor
_editors="/opt/homebrew/bin/nvim"
for e in ${_editors}; do
  if [ -f "${e}" ]; then
    export EDITOR="${e}"
    export SYSTEMD_EDITOR="${e}"
    export SUDO_EDITOR="${e}"
    export DIFFPROG="${e} -d"
    break
  fi
done
unset _editors

return 0

# vim: set filetype=sh:
