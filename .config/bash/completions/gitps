# shellcheck shell=bash

# shellcheck disable=SC1091
. "${BASH_COMPLETION_USER_DIR}/completions/_git.wrapper"

if ! declare -f __git_alias_push >/dev/null 2>&1; then
  __git_alias_push() {
    __git_alias_wrap "push" "$@"
  }

  complete -o bashdefault -o default -o nospace -F __git_alias_push gitps
fi

