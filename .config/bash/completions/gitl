# shellcheck shell=bash

# shellcheck disable=SC1091
. "${BASH_COMPLETION_USER_DIR}/completions/_git.wrapper"

if ! declare -f __git_alias_log >/dev/null 2>&1; then
  __git_alias_log() {
    # lg is our log alias
    __git_alias_wrap "lg" "$@"
  }

  complete -o bashdefault -o default -o nospace -F __git_alias_log gitl
fi

